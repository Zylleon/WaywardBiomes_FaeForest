<?xml version="1.0" encoding="utf-8"?>
<Defs>


	<ThingDef ParentName="PlantBase">
		<defName>ZWB_DarkGrass</defName>
		<label>dark grass</label>
		<description>Wild tall grass. Slows down anyone moving over it.</description>
		<statBases>
			<MaxHitPoints>90</MaxHitPoints>
			<Flammability>1.3</Flammability>
			<Nutrition>0.50</Nutrition>
		</statBases>
		<pathCost>14</pathCost>
		<graphicData>
			<texPath>ZWB_Textures/Plants/DarkGrass</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<hideAtSnowOrSandDepth>0.5</hideAtSnowOrSandDepth>
		<ingestible/>
		<plant>
			<fertilitySensitivity>0.7</fertilitySensitivity>
			<growDays>3</growDays>
			<harvestWork>60</harvestWork>
			<maxMeshCount>9</maxMeshCount>
			<visualSizeRange>0.7~0.95</visualSizeRange>
			<topWindExposure>0.4</topWindExposure>
			<wildClusterRadius>4</wildClusterRadius>
			<wildClusterWeight>10</wildClusterWeight>
			<wildOrder>1</wildOrder>
			<maxGrowthTemperature>75</maxGrowthTemperature>
		</plant>
	</ThingDef>


